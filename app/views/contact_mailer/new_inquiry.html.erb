<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <style>
    body { font-family: system-ui, sans-serif; background: #f5f5f0; margin: 0; padding: 32px; color: #1a1a1a; }
    .card { background: #fff; border-radius: 8px; max-width: 560px; margin: 0 auto; padding: 40px; border-top: 4px solid #1d4d35; }
    h1 { font-size: 1.3rem; color: #1d4d35; margin: 0 0 24px; }
    .row { margin-bottom: 16px; }
    .label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: #888; margin-bottom: 4px; }
    .value { font-size: 0.95rem; color: #1a1a1a; }
    .message-box { background: #f5f5f0; border-radius: 6px; padding: 16px; margin-top: 4px; font-size: 0.9rem; line-height: 1.6; white-space: pre-wrap; }
    .footer { margin-top: 32px; padding-top: 16px; border-top: 1px solid #eee; font-size: 0.78rem; color: #aaa; }
  </style>
</head>
<body>
  <div class="card">
    <h1>Nouvelle demande de contact</h1>

    <div class="row">
      <div class="label">Nom complet</div>
      <div class="value"><%= @params[:prenom] %> <%= @params[:nom] %></div>
    </div>

    <div class="row">
      <div class="label">Email</div>
      <div class="value"><a href="mailto:<%= @params[:email] %>"><%= @params[:email] %></a></div>
    </div>

    <% if @params[:telephone].present? %>
    <div class="row">
      <div class="label">Téléphone</div>
      <div class="value"><%= @params[:telephone] %></div>
    </div>
    <% end %>

    <div class="row">
      <div class="label">Type de structure</div>
      <div class="value"><%= @params[:structure] %></div>
    </div>

    <% if @params[:message].present? %>
    <div class="row">
      <div class="label">Message</div>
      <div class="message-box"><%= @params[:message] %></div>
    </div>
    <% end %>

    <div class="footer">
      Reçu le <%= @received_at.strftime('%d/%m/%Y à %Hh%M') %>
    </div>
  </div>
</body>
</html>
