<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Administration — Eric Cuisine</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #f4f3ef; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .card { background: #fff; border-radius: 16px; padding: 48px; width: min(440px, calc(100vw - 40px)); box-shadow: 0 24px 60px rgba(0,0,0,0.08); }
    h1 { font-size: 1.5rem; color: #111; margin-bottom: 8px; }
    .subtitle { color: #888; font-size: 0.9rem; margin-bottom: 32px; line-height: 1.6; }
    .error { color: #b83232; font-size: 0.88rem; margin-bottom: 16px; }
    label { display: block; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #444; margin-bottom: 8px; }
    input[type=password] { width: 100%; border: 1px solid #e2e2e2; border-radius: 10px; padding: 12px 14px; font-size: 0.95rem; color: #111; background: #f8f7f4; outline: none; transition: border-color 0.2s; }
    input[type=password]:focus { border-color: #1d4d35; }
    button { margin-top: 20px; width: 100%; background: #1d4d35; color: #fff; border: none; border-radius: 10px; padding: 14px; font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: background 0.2s; }
    button:hover { background: #2a6b4a; }
  </style>
</head>
<body>
  <div class="card">
    <h1>Eric Cuisine</h1>
    <p class="subtitle">Espace d'administration — modifiez le contenu de votre site.</p>
    <% if flash[:error] %>
      <p class="error"><%= flash[:error] %></p>
    <% end %>
    <%= form_with url: admin_session_path do |f| %>
      <label for="password">Mot de passe</label>
      <%= f.password_field :password, id: 'password', placeholder: '••••••••', autofocus: true %>
      <%= f.submit 'Se connecter' %>
    <% end %>
  </div>
</body>
</html>
